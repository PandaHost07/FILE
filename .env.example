# --- PostgreSQL (Neon / Supabase / Railway) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Auth.js — wajib di production (generate: openssl rand -base64 32)
AUTH_SECRET="ganti-dengan-string-acak-panjang"

# URL publik app (Vercel: https://domain-anda.vercel.app)
AUTH_URL="http://localhost:3000"

# Admin / backend: daftar user & lihat snapshot data (jangan expose ke frontend)
# Contoh curl: curl -H "Authorization: Bearer $ADMIN_API_SECRET" https://.../api/admin/users
ADMIN_API_SECRET="ganti-dengan-string-rahasia-panjang"
